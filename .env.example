# =============================================================================
# .env.example
# Copia este archivo como ".env" y reemplaza todos los valores antes de
# ejecutar "docker compose up -d". NUNCA subas el .env real a un repositorio.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=moodle_user
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
MOODLE_DATABASE_NAME=moodle_db
# Host interno (nombre del servicio en la red de backend). No cambiar salvo
# que renombres el servicio "db" en docker-compose.yml.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Moodle ---
# FASE LABORATORIO: acceso por IP en intranet, sin TLS. Usa http:// y la IP
# real del servidor (ej. http://192.168.1.50). Cuando pases a producción con
# dominio + TLS, cambia esto a https://tu-dominio y reconfigura wwwroot
# dentro de Moodle (Administración del sitio > Servidor > HTTP/HTTPS).
MOODLE_SITE_URL=http://192.168.1.50

# Cuenta de administrador creada por install-moodle.sh durante la
# instalación inicial. Cámbiala después del primer ingreso si lo deseas.
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA_2
MOODLE_ADMIN_EMAIL=admin@tudominio.local

# --- PHP-FPM ---
# Los límites de PHP (memory_limit, upload_max_filesize, post_max_size) se
# configuran directamente en php/php.ini, ya que PHP no interpola
# variables de entorno dentro de su archivo de configuración.

# --- Zona horaria contenedores ---
TZ=America/Bogota
